generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusTarefa {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model Tarefa {
  id          Int         @id @default(autoincrement())
  titulo      String     @db.VarChar(255)
  descricao   String?    @db.Text
  status      StatusTarefa @default(PENDENTE)
  dataCriacao DateTime   @default(now())

  @@map("tarefas")
}